# to run shacl verification use this command:
# pyshacl -s ../jupiterli/ttl/jli-shacl.ttl producer.ttl

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix jli: <http://example.com/jupiterli#> .
@prefix : <http://example.com/scratch#> .

:fig1 a jli:Plot; jli:title "FIG 1" .
:fig1_c1 a jli:Scatter; jli:title "trace0"; jli:on_plot :fig1; jli:redis_key "data1"; jli:line_color [ a jli:Color; rdf:value "red" ].
:fig1_c2 a jli:Scatter; jli:title "trace1"; jli:on_plot :fig1; jli:redis_key "data2" .

:fig2 a jli:Plot; jli:title "fig2" .
:fig2_c1 a jli:Histogram; jli:title "trace1"; jli:on_plot :fig2; jli:redis_key "data1" .

:fig3 a jli:Plot; jli:title "fig3" .
:fig3_c1 a jli:TimeseriesScatter; jli:title "trace0"; jli:on_plot :fig3; jli:redis_key "data1" .
